# .env.example — Variables de entorno para Open Liveness
# Copia este archivo a .env.local y ajusta los valores para desarrollo local.
# En Railway, configura estas variables en el dashboard del servicio.

# ─── FRONTEND (Vite) ─────────────────────────────────────────────────────────
# URL del backend API.
# Dev local: dejar vacío (apunta a http://localhost:8000 por defecto)
# Producción Railway: https://<tu-backend>.up.railway.app
VITE_API_URL=

# ─── BACKEND (FastAPI) ───────────────────────────────────────────────────────
# Orígenes CORS permitidos (separados por comas).
# Dev local: dejar vacío (permite localhost:5173 y :5174 por defecto)
# Producción Railway: https://<tu-frontend>.up.railway.app
ALLOWED_ORIGINS=
